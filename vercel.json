{
  "crons": [
    {
      "path": "/api/cron-reminders",
      "schedule": "0 10 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": "(?i).*text/html.*"
        }
      ],
      "destination": "/index.html"
    }
  ]
}